# ===== 应用 =====
APP_NAME=行政事业单位文档合规检查智能体
DEBUG=false

# ===== 数据库 =====
# 本地零配置可用 SQLite（留空走默认）；生产用 PostgreSQL：
DATABASE_URL=postgresql://compliance:change_me@postgres:5432/compliance
POSTGRES_USER=compliance
POSTGRES_PASSWORD=change_me
POSTGRES_DB=compliance

# ===== 对象存储 =====
STORAGE_DIR=/app/storage
# 生产可接 MinIO/OSS（Phase 2 接入）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me

# ===== Redis（Celery broker + 缓存）=====
REDIS_URL=redis://redis:6379/0
# Celery：true = 同步执行（开发离线默认），false = 由 worker 异步消费（生产）
CELERY_EAGER=false

# ===== Embedding：stub | bge =====
# 离线默认 stub（无需下载模型）；安装 sentence-transformers 后改 bge
EMBEDDER=stub
EMBEDDING_DIM=256
BGE_MODEL_NAME=BAAI/bge-large-zh-v1.5

# ===== 向量库：memory | qdrant =====
VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333

# ===== LLM：stub | claude =====
# 留空 key 时自动降级为 stub（仅刚性规则生效）
LLM_PROVIDER=stub
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# ===== 宿主机端口映射（默认标准端口；本机端口被占用时改这里即可）=====
BACKEND_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
QDRANT_HOST_PORT=6333
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
NGINX_HOST_PORT=80
